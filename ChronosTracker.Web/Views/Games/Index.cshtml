@model IEnumerable<ChronosTracker.Core.Entities.Game>

@{
    ViewData["Title"] = "My Library";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Game Library</h1>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Back to Import</a>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Release Date</th>
                <th>Steam Rating</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var game in Model)
            {
                <tr>
                    <td>@game.Title</td>
                    <td>@game.ReleaseDate?.ToString("yyyy-MM-dd")</td>
                    <td>@game.SteamRating</td>
                    <td><span class="badge bg-info">In Library</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>