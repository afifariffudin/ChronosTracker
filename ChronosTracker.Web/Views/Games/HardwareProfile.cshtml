@using ChronosTracker.Infrastructure.Models
@model List<IGDBNestedItem>
@{
    ViewData["Title"] = "Hardware Setup";
    var selectedPlatforms = ViewBag.SelectedPlatforms as List<int> ?? new List<int>();
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                    <h3 class="mb-0"><i class="bi bi-cpu"></i> Global Hardware Profile</h3>
                    <a asp-action="Browse" class="btn btn-sm btn-outline-light">Back to Archive</a>
                </div>
                <div class="card-body">
                    <p class="text-muted">Select the platforms you own or care about. The Archive will automatically apply these filters every time you browse.</p>

                    <div class="input-group mb-4">
                        <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                        <input type="text" id="platformSearch" class="form-control" placeholder="Search for a console (e.g. PlayStation 5, Sega Genesis)..." onkeyup="filterPlatforms()">
                    </div>

                    <form asp-action="SaveHardwareProfile" method="post">
                        <div class="row" id="platformList" style="max-height: 500px; overflow-y: auto;">
                            @foreach (var platform in Model.OrderBy(p => p.name))
                            {
                                <div class="col-md-6 platform-item mb-2">
                                    <div class="form-check p-2 border rounded hover-bg-light shadow-sm">
                                        <input class="form-check-input ms-1" type="checkbox" name="platformIds" value="@platform.id" id="plt_@platform.id"
                                               @(selectedPlatforms.Contains(platform.id) ? "checked" : "")>
                                        <label class="form-check-label ms-2 fw-bold" for="plt_@platform.id">
                                            @platform.name
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-4 pt-3 border-top d-grid">
                            <button type="submit" class="btn btn-primary btn-lg shadow">
                                <i class="bi bi-save"></i> Save Profile & Apply to Archive
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple search logic to filter the consoles in the setup list
        function filterPlatforms() {
            let input = document.getElementById('platformSearch').value.toLowerCase();
            let items = document.getElementsByClassName('platform-item');
            for (let i = 0; i < items.length; i++) {
                let text = items[i].innerText.toLowerCase();
                items[i].style.display = text.includes(input) ? "" : "none";
            }
        }
    </script>
    <style>
        .hover-bg-light:hover {
            background-color: #f8f9fa;
            cursor: pointer;
            border-color: #0d6efd !important;
        }
    </style>
}