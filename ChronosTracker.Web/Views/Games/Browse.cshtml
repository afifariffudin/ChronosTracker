@using ChronosTracker.Infrastructure.Models
@using System.Web
@model List<IGDBGame>

@{
    ViewData["Title"] = "Global Game Archive";
    var platforms = ViewBag.Platforms as List<IGDBNestedItem> ?? new List<IGDBNestedItem>();
    var selectedPlatforms = ViewBag.SelectedPlatforms as List<int> ?? new List<int>();
    var localStatuses = ViewBag.LocalStatuses as Dictionary<int, int> ?? new Dictionary<int, int>();
    var localDatesStarted = ViewBag.LocalDatesStarted as Dictionary<int, DateTime?> ?? new Dictionary<int, DateTime?>();
    var localDatesFinished = ViewBag.LocalDatesFinished as Dictionary<int, DateTime?> ?? new Dictionary<int, DateTime?>();
    string searchTerm = ViewBag.SearchTerm;

    // We no longer need currentPage or totalPages for the logic
    long? nextTimestamp = ViewBag.NextTimestamp; // The cursor for the "Next" button
    long? minDate = ViewBag.MinDate; // The cursor we started this page with
}

<style>
    :root {
        --bg-deep: #0f0f0f;
        --surface-card: #1a1a1a;
        --accent-purple: #bb86fc;
        --accent-teal: #03dac6;
        --border-soft: #2c2c2c;
        --text-muted: #a0a0a0;
    }

    body {
        background-color: var(--bg-deep);
        color: #e0e0e0;
        overflow: hidden;
    }

    .table-responsive {
        height: 85vh;
        overflow: auto;
        scrollbar-width: thin;
        scrollbar-color: var(--border-soft) transparent;
    }

    /* 1. Sticky Header */
    .table-archive thead th {
        position: sticky;
        top: 0;
        z-index: 20;
        background-color: #252525 !important;
        border-bottom: 2px solid var(--border-soft);
        color: var(--accent-purple);
        font-weight: 600;
        text-transform: uppercase;
    }

    thead th.sticky-action {
        z-index: 30;
        top: 0;
        right: 0;
        background-color: #252525 !important;
    }

    /* 2. Sticky Action Column */
    .sticky-action {
        position: sticky;
        right: 0;
        background-color: #1a1a1a !important;
        z-index: 10;
        border-left: 1px solid var(--border-soft);
    }

    /* 3. Table Styling */
    .table-archive {
        font-size: 0.85rem;
        background-color: transparent !important;
    }

        .table-archive tbody tr {
            border-bottom: 1px solid var(--border-soft);
            transition: 0.2s;
        }

            .table-archive tbody tr:hover {
                background-color: #242424 !important;
            }

    .game-summary-scroll {
        max-height: 85px;
        overflow-y: auto;
        font-size: 0.8rem;
        line-height: 1.5;
        padding-right: 10px;
        color: var(--text-muted);
    }

    .game-cover {
        width: 55px;
        height: 75px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid var(--border-soft);
    }

    .badge-platform {
        background: rgba(187, 134, 252, 0.1);
        color: var(--accent-purple);
        border: 1px solid rgba(187, 134, 252, 0.3);
    }

    .badge-genre {
        background: rgba(3, 218, 198, 0.1);
        color: var(--accent-teal);
        border: 1px solid rgba(3, 218, 198, 0.3);
    }

    #sidebarCollapse {
        transition: all 0.3s ease;
        background: var(--surface-card);
        border-right: 1px solid var(--border-soft);
    }

    .page-indicator {
        min-width: 90px;
        text-align: center;
        border-left: 1px solid var(--border-soft);
        border-right: 1px solid var(--border-soft);
    }

    /* Steam Link Interaction */
    .hover-purple:hover {
        color: var(--accent-purple) !important;
    }

    .worth-meter {
        border: 1px solid var(--border-soft);
        border-radius: 8px;
        padding: 4px;
        text-align: center;
        min-width: 65px;
    }

    .worth-high {
        border-color: var(--accent-teal);
        color: var(--accent-teal);
    }

    .popular-flame {
        color: #ff5f00;
        margin-left: 4px;
        filter: drop-shadow(0 0 2px rgba(255,95,0,0.5));
    }

    /* Finished Game Gray-out */
    .is-finished {
        opacity: 0.3;
        filter: grayscale(100%);
        transition: 0.4s;
    }

        .is-finished:hover {
            opacity: 0.7;
            filter: grayscale(20%);
        }
</style>

        <div class="container-fluid px-4 mt-2">
            <div class="d-flex justify-content-between align-items-center mb-3 bg-dark p-2 rounded border border-secondary shadow-sm">
                <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-sm btn-outline-light" type="button" id="sidebarToggleBtn" data-bs-toggle="collapse" data-bs-target="#sidebarCollapse">
                        <i class="bi bi-layout-sidebar-inset"></i>
                    </button>

                    <div class="btn-group btn-group-sm ms-2">
            @* RESET: Takes you back to the very beginning (1970) *@
            @if (minDate != null && minDate > 0)
            {
                <a class="btn btn-outline-secondary" title="Reset to Beginning"
                   href="@Url.Action("Browse", new { platformIds = selectedPlatforms, searchTerm = searchTerm })">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </a>
            }

            @* PREVIOUS: This is tricky. For now, the best 'Previous' is a Reset or using Browser Back. 
               True 'Back' in Timestamps requires a 'History Stack'. *@
    
            <span class="btn btn-dark border-secondary px-3 fw-bold text-purple page-indicator" style="color:var(--accent-purple)">
                @if (Model.Any())
                {
                    @Model.First().ReleaseDate?.ToString("yyyy") @:- @Model.Last().ReleaseDate?.ToString("yyyy")
                }
                else
                {
                    @:ERA VIEW
                }
            </span>

            @* NEXT ERA: The core of your 'Always 50' logic *@
            @if (Model.Count >= 50)
            {
                <a class="btn btn-primary fw-bold" title="Next 50 New Games"
                   href="@Url.Action("Browse", new { lastTimestamp = nextTimestamp, platformIds = selectedPlatforms, searchTerm = searchTerm })">
                    Next Era <i class="bi bi-chevron-right"></i>
                </a>
            }
        </div>

            <form asp-action="Browse" method="get" class="ms-3">
                @* Keep platforms, but DO NOT include lastTimestamp here so search starts from 1970 *@
                @foreach (var id in selectedPlatforms)
                {
                    <input type="hidden" name="platformIds" value="@id" />
                }
                <div class="input-group input-group-sm" style="width: 300px;">
                    <input type="text" name="searchTerm" class="form-control bg-transparent border-secondary text-light"
                           placeholder="Search all eras..." value="@searchTerm">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>
        </div>

        <div class="form-check form-switch pt-1 ms-3">
            <input class="form-check-input" type="checkbox" id="hideFinishedToggle" onchange="toggleFinishedRows()">
            <label class="form-check-label small fw-bold text-success mb-0" for="hideFinishedToggle">Hide Finished</label>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="form-check form-switch pt-1">
                <input class="form-check-input" type="checkbox" id="showHiddenToggle" onchange="toggleHiddenRows()">
                <label class="form-check-label small fw-bold text-danger mb-0" for="showHiddenToggle">Show Hidden</label>
            </div>
            <h5 class="mb-0 fw-bold border-start border-secondary ps-3 ms-2 text-uppercase">Global Archive</h5>
        </div>
    </div>

    <div class="row g-0">
        <div class="collapse collapse-horizontal col-md-3 col-lg-2" id="sidebarCollapse">
            <div class="p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="small fw-bold text-muted text-uppercase">Platforms</span>
                    <a asp-action="HardwareProfile" class="text-muted"><i class="bi bi-gear-fill"></i></a>
                </div>
                <input type="text" id="platformSearch" class="form-control form-control-sm bg-dark border-secondary text-light mb-3"
                       placeholder="Filter platforms..." onkeyup="filterPlatformList()">

                <div id="platformCheckboxContainer" style="max-height: 65vh; overflow-y: auto;" class="pe-2">
                    @foreach (var p in platforms.OrderBy(x => x.name))
                    {
                        <div class="form-check platform-row mb-2">
                            <input class="form-check-input" type="checkbox" name="platformIds" value="@p.id" id="plt_@p.id"
                                   @(selectedPlatforms.Contains(p.id) ? "checked" : "") onchange="this.form.submit()">
                            <label class="form-check-label small text-muted" for="plt_@p.id">@p.name</label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col px-3">
            <div class="card shadow-lg border-0 overflow-hidden" style="background:transparent">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 table-archive">
                        <thead>
                            <tr class="small">
                                <th class="text-center align-middle sticky-action px-3" style="width:120px;">ACTION</th>
                                <th class="col-date ps-3 text-center align-middle">RELEASE</th>
                                <th class="text-center align-middle">COVER</th>
                                <th class="col-details text-center align-middle">GAME DETAILS</th>
                                <th class="text-center align-middle">DEVELOPER</th>
                                <th class="text-center align-middle">GENRES</th>
                                <th class="text-center align-middle">PARENT GAME</th>
                                <th class="text-center align-middle">SERIES</th>
                                <th class="text-center align-middle">FRANCHISE</th>
                                <th class="text-center align-middle">PLATFORMS</th>
                                <th class="text-center align-middle" style="width: 100px;">WORTH</th>
                                <th class="text-center align-middle" style="width:150px;">START</th>
                                <th class="text-center align-middle" style="width:150px;">FINISH</th>
                                <th class="text-center align-middle" style="width:120px;">PLAY STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var game in Model)
                            {
                                var safeTitle = HttpUtility.JavaScriptStringEncode(game.name ?? "");
                                var safeSeries = HttpUtility.JavaScriptStringEncode(game.collection?.name ?? "");
                                var safeFranchise = HttpUtility.JavaScriptStringEncode(game.franchises?.FirstOrDefault()?.name ?? "");
                                var startDate = localDatesStarted.GetValueOrDefault(game.id);
                                var finishDate = localDatesFinished.GetValueOrDefault(game.id);

                                string playStatus = "Shelf";
                                string statusClass = "text-muted opacity-50";

                                if (startDate.HasValue && finishDate.HasValue)
                                {
                                    playStatus = "Finished";
                                    statusClass = "text-success fw-bold";
                                }
                                else if (startDate.HasValue)
                                {
                                    playStatus = "Playing";
                                    statusClass = "text-warning fw-bold";
                                }

                                int s = localStatuses.GetValueOrDefault(game.id, 0);
                                var cover = !string.IsNullOrEmpty(game.cover?.url) ? "https:" + game.cover.url.Replace("t_thumb", "t_cover_big") : "";

                                <tr id="row_@game.id" 
                                    class="@(s == 2 ? "d-none is-hidden-row" : "") @(playStatus == "Finished" ? "is-finished-row" : "")"
                                    style="@(s == 2 ? "opacity: 0.3;" : "")">
 
                                    @* ACTION *@
                                    <td class="text-center sticky-action px-3">
                                        <div id="actions_@game.id" class="btn-group btn-group-sm">
                                            @if (s == 2)
                                            {
                                                <button class="btn btn-warning" onclick="updateStatus(@game.id, '@safeTitle', '@cover', '@game.ReleaseDate', 0)"><i class="bi bi-arrow-counterclockwise"></i></button>
                                            }
                                            else
                                            {
                                                @* Add/Interested Button *@
                                                <button class="btn @(s == 1 ? "btn-success" : "btn-outline-success")" style="@(s == 1 ? "" : "color:var(--accent-teal); border-color:var(--accent-teal)")"
                                                        onclick="updateStatus(@game.id, '@safeTitle', '@cover', '@game.ReleaseDate', 1, '@safeSeries', '@safeFranchise', @game.SupportsEnglish.ToString().ToLower())">
                                                    <i class="bi @(s == 1 ? "bi-check-circle-fill" : "bi-plus-circle")"></i>
                                                </button>
                                                @* Hide Button *@
                                                <button class="btn btn-outline-danger"
                                                        onclick="updateStatus(@game.id, '@safeTitle', '@cover', '@game.ReleaseDate', 2, '@safeSeries', '@safeFranchise', @game.SupportsEnglish.ToString().ToLower())">
                                                    <i class="bi bi-eye-slash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>

                                @* RELEASE *@
                                    <td class="text-center text-nowrap fw-bold px-3">@game.ReleaseDate?.ToString("dd-MMM-yyyy")</td>
                                    @* COVER *@
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(cover))
                                        {
                                            <img src="@cover" class="game-cover" />
                                        }
                                    </td>
                                    @* GAME DETAILS *@
                                    <td>
                                        <div class="d-flex justify-content-between align-items-start w-100 mb-2">
                                            <a href="@game.url" target="_blank" class="fw-bold text-light text-decoration-none hover-purple fs-5">
                                                @game.name
                                            </a>

                                            <div class="d-flex gap-2 ms-3 flex-shrink-0">
                                                @* STEAM *@
                                                @if (!string.IsNullOrEmpty(game.SteamAppId))
                                                {
                                                    <a href="@game.SteamAppId" target="_blank" class="text-info opacity-75" title="View on Steam">
                                                        <i class="fa-brands fa-steam" style="font-size: 1.2rem;"></i>
                                                    </a>
                                                }

                                                @* GOG *@
                                                @if (!string.IsNullOrEmpty(game.GOGId))
                                                {
                                                    <a href="@game.GOGId" target="_blank" style="color: #b245ff;" class="opacity-75" title="View on GOG">
                                                        <i class="fa-solid fa-g" style="font-size: 1.1rem;filter: drop-shadow(0 0 2px #b245ff);"></i>
                                                    </a>
                                                }

                                                @* EPIC GAMES *@
                                                @if (!string.IsNullOrEmpty(game.EpicGamesId))
                                                {
                                                    <a href="@game.EpicGamesId" target="_blank" style="color: #ffffff;" class="opacity-75" title="View on Epic Games Store">
                                                        <i class="fa-solid fa-e" style="font-size: 1.1rem;border: 1px solid white; padding: 1px 4px; border-radius: 4px; line-height: 1;"></i>
                                                    </a>
                                                }
                                            </div>
                                        </div>

                                        <div class="w-100">
                                            <div class="game-summary-scroll text-muted border-top border-secondary pt-1" style="display: block; width: 100%; ">
                                                @if (string.IsNullOrWhiteSpace(game.summary))
                                                {
                                                    <span class="fst-italic opacity-50">No description available.</span>
                                                }
                                                else
                                                {
                                                    @game.summary
                                                }

                                            </div>
                                        </div>
                                    </td>

                                    @* DEVELOPER *@
                                    <td class="small text-muted">@(game.involved_companies != null ? string.Join(", ", game.involved_companies.Where(c => c.developer).Select(c => c.company.name)) : "-")</td>

                                    @* GENRES *@
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @if (game.genres != null)
                                            {
                                                @foreach (var g in game.genres)
                                                {
                                                    <span class="badge badge-genre" style="font-size:0.65rem;">@g.name</span>
                                                }
                                            }
                                        </div>
                                    </td>

                                    @* PARENT GAME *@
                                    <td class="small text-muted">
                                        @if (game.parent_game != null)
                                        {
                                            <a href="@Url.Action("Browse", new { searchTerm = game.parent_game.name })"
                                               class="text-muted text-decoration-none hover-purple">
                                                @game.parent_game.name
                                            </a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>

                                    @* SERIES *@
                                    <td class="small text-muted">
                                        @if (game.collection != null)
                                        {
                                            <a href="@Url.Action("Browse", new { searchTerm = game.collection.name })"
                                               class="text-muted text-decoration-none hover-purple">
                                                @game.collection.name
                                            </a>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }

                                    </td>

                                    @* FRANCHISE *@
                                    <td class="small text-muted">
                                        @if (game.franchises != null && game.franchises.Any())
                                        {
                                            <div class="d-flex flex-column gap-1">
                                                @foreach (var f in game.franchises)
                                                {
                                                    <a href="@Url.Action("Browse", new { searchTerm = f.name })"
                                                       class="text-muted text-decoration-none hover-purple">
                                                        @f.name
                                                    </a>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>

                                    @* PLATFORMS *@
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @if (game.platforms != null)
                                            {
                                                @foreach (var pl in game.platforms)
                                                {
                                                    <span class="badge badge-platform" style="font-size:0.65rem;">@pl.name</span>
                                                }
                                            }
                                        </div>
                                    </td>

                                    @* WORTH *@
                                    <td class="text-center">
                                        <div class="worth-meter @(game.WorthinessScore > 80 ? "worth-high" : "")">
                                            <div class="fw-bold">@game.WorthinessScore%</div>
                                            <div style="font-size: 0.6rem;" class="text-muted">n=@game.total_rating_count</div>
                                            @if ((game.hypes ?? 0) > 50)
                                            {
                                                <i class="bi bi-fire popular-flame" title="High Popularity (Hype)"></i>
                                            }
                                        </div>
                                    </td>

                                    @* START DATE *@
                                    <td class="px-2">
                                        <input type="date" class="form-control form-control-sm bg-dark text-light border-secondary"
                                               value="@(localDatesStarted.GetValueOrDefault(game.id)?.ToString("yyyy-MM-dd"))"
                                               onchange="updateDate(@game.id, 'start', this.value)" />
                                    </td>

                                    @* FINISH DATE *@
                                    <td class="px-2">
                                        <input type="date" class="form-control form-control-sm bg-dark text-light border-secondary"
                                               value="@(localDatesFinished.GetValueOrDefault(game.id)?.ToString("yyyy-MM-dd"))"
                                               onchange="updateDate(@game.id, 'finish', this.value)" />
                                    </td>

                                    @* PLAY STATUS *@
                                    <td class="text-center small @statusClass">
                                        @playStatus.ToUpper()
                                    </td>

                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sidebar = document.getElementById('sidebarCollapse');
            const sidebarState = localStorage.getItem('sidebarState');
            if (sidebarState === 'open') { sidebar.classList.add('show'); }
            else { sidebar.classList.remove('show'); }
            sidebar.addEventListener('shown.bs.collapse', () => localStorage.setItem('sidebarState', 'open'));
            sidebar.addEventListener('hidden.bs.collapse', () => localStorage.setItem('sidebarState', 'closed'));
        });

        function updateStatus(id, title, cover, date, status, series, franchise, supportsEnglish) {
                    $.post('/Games/UpdateStatus', {
                        igdbId: id,
                        title: title,
                        coverUrl: cover,
                        releaseDate: date,
                        status: status,
                        seriesname : series,
                        franchisename : franchise,
                        supportsEnglish: supportsEnglish
                    }, function (res) {
                        if (res.success) {
                            const row = $(`#row_${id}`);

                            if (status == 2) {
                                // Visual 'Hide' logic
                                row.addClass('is-hidden-row').css('opacity', '0.3');
                                if (!$('#showHiddenToggle').is(':checked')) {
                                    row.fadeOut(300);
                                }
                            } else {
                                location.reload();
                            }
                        }
                    });
                }

        function toggleHiddenRows() {
            // 1. Get the True/False state of the switch
            const isChecked = $('#showHiddenToggle').is(':checked');

            // 2. Find every row marked as "hidden"
            const hiddenRows = $('.is-hidden-row');

            if (isChecked) {
                hiddenRows.removeClass('d-none').fadeIn(200);
            } else {
                hiddenRows.addClass('d-none');
            }
        }

        function filterPlatformList() {
            const term = $('#platformSearch').val().toLowerCase();
            $('.platform-row').each(function () {
                $(this).toggle($(this).text().toLowerCase().includes(term));
            });
        }

                function toggleFinishedRows() {
            const shouldHide = $('#hideFinishedToggle').is(':checked');
            const finishedRows = $('.is-finished-row');

            if (shouldHide) {
                finishedRows.addClass('d-none');
            } else {
                // Only show them if they aren't ALSO "Hidden" (Status 2)
                finishedRows.each(function() {
                    if (!$(this).hasClass('is-hidden-row')) {
                        $(this).removeClass('d-none');
                    }
                });
            }
        }

                function updateDate(id, type, dateValue) {
            $.post('/Games/UpdateDates', {
                igdbId: id,
                type: type,
                date: dateValue
            }, function (res) {
                if (res.success) {
                    location.reload();

                } else {
                        alert(res.message);
                }
            });
        }
    </script>
}