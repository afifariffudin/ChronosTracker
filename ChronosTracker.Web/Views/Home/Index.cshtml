@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Chronos Tracker</h1>
    <p>Your Excel Importer is ready.</p>

    <hr />

    <form asp-controller="Games" asp-action="Import" method="post">
        <button type="submit" class="btn btn-success btn-lg" style="padding: 20px; font-size: 20px;">
            🚀 Import Games from Excel
        </button>
    </form>

    @if (TempData["IGDBStatus"] != null)
    {
        <div class="alert alert-info mt-3">
            @TempData["IGDBStatus"]
        </div>
    }

    <div class="mt-5 border-top pt-3">
        <h3>IGDB API Testing</h3>
        <form asp-controller="Games" asp-action="TestIGDB" method="post">
            <button type="submit" class="btn btn-primary">Verify IGDB Connection</button>
        </form>
    </div>

</div>